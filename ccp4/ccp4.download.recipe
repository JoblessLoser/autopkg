<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Comment</key>
	<string>Created with Recipe Robot v2.5.0 (https://github.com/homebysix/recipe-robot)</string>
	<key>Description</key>
	<string>Downloads the latest version of ccp4</string>
	<key>Identifier</key>
	<string>com.github.JoblessLoser.download.ccp4</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>ccp4</string>
		<key>SUPPORTED_ARCH</key>
		<string>arm64</string>
		<!-- alt x86_64 -->
		<key>DOWNLOAD_ARCH</key>
		<string>arm64</string>
		<!-- alt x64 -->
	</dict>
	<key>MinimumVersion</key>
	<string>2.3</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>re_pattern</key>
				<string>v([0-9]+\.[0-9]+\.[0-9]+)</string>
				<key>result_output_var_name</key>
				<string>VERSION</string>
				<key>url</key>
				<string>https://ccp4serv6.rc-harwell.ac.uk/9/downloads/#os=macos</string>
			</dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>re_pattern</key>
				<string>sid=([^&quot;]*)</string>
				<key>result_output_var_name</key>
				<string>ID</string>
				<key>url</key>
				<string>https://ccp4serv6.rc-harwell.ac.uk/9/downloads/#os=macos</string>
			</dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>curl_opts</key>
				<array>
            		<string>-X</string>
            		<string>POST</string>
					<string>-F</string>
            		<string>id=%ID%</string>
					<string>-F</string>
            		<string>pkg=ccp4-%DOWNLOAD_ARCH%</string>
					<string>-F</string>
            		<string>subpackage=ccp4</string>
					<string>-F</string>
            		<string>os=macos</string>
					<string>-F</string>
            		<string>sid=%ID%</string>
					<string>-F</string>
            		<string>result=accept</string>
				</array>
				<key>url</key>
				<string>https://ccp4serv6.rc-harwell.ac.uk/9/downloads/licence.php?pkg=ccp4-%DOWNLOAD_ARCH%&amp;os=macos&amp;sid=%ID%</string>
			</dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLDownloader</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>https://www.ccp4.ac.uk/download/download_file.php?os=macos&amp;pkg=ccp4-%DOWNLOAD_ARCH%&amp;sid=%ID%</string>
				<key>filename</key>
				<string>ccp4-%VERSION%-macos%DOWNLOAD_ARCH%.tar.gz</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>EndOfCheckPhase</string>
		</dict>
	</array>
</dict>
</plist>
