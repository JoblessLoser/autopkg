<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Comment</key>
	<string>Created with Recipe Robot v2.5.0 (https://github.com/homebysix/recipe-robot)</string>
	<key>Description</key>
	<string>Downloads the latest version of ccp4</string>
	<key>Identifier</key>
	<string>com.github.JoblessLoser.download.ccp4</string>
	<key>Input</key>
	<dict>
		<key>NAME</key>
		<string>ccp4</string>
		<key>SUPPORTED_ARCH</key>
		<string>arm64</string>z
	</dict>
	<key>MinimumVersion</key>
	<string>2.3</string>
	<key>Process</key>
	<array>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>re_pattern</key>
				<string>v[0-9]+\.[0-9]+\.[0-9]+</string>
				<key>result_output_var_name</key>
				<string>VERSION</string>
				<key>url</key>
				<string>https://ccp4serv6.rc-harwell.ac.uk/9/downloads/#os=macos</string>
			</dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>re_pattern</key>
				<string>sid=[^&quot;]*</string>
				<key>result_output_var_name</key>
				<string>SID</string>
				<key>url</key>
				<string>https://ccp4serv6.rc-harwell.ac.uk/9/downloads/#os=macos</string>
			</dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
		</dict>
		<dict>
			<key>Arguments</key>
			<dict>
				<key>re_pattern</key>
				<string>sid=[^&quot;]*</string>
				<key>result_output_var_name</key>
				<string>DOWNLOAD_URL</string>
				<key>url</key>
				<string>https://ccp4serv6.rc-harwell.ac.uk/9/downloads/licence.php?pkg=ccp4-%SUPPORTED_ARCH%&amp;os=macos&amp;%SID%</string>
			</dict>
			<key>Processor</key>
			<string>URLTextSearcher</string>
		</dict>
		<dict>
			<key>Processor</key>
			<string>URLDownloader</string>
			<key>Arguments</key>
			<dict>
				<key>url</key>
				<string>https://www.ccp4.ac.uk/download/download_file.php?os=macos&amp;pkg=ccp4-%SUPPORTED_ARCH%&amp;%DOWNLOAD_URL%</string>
				<key>filename</key>
				<string>ccp4-%VERSION%-macos%SUPPORTED_ARCH%.tar.gz</string>
			</dict>
		</dict>
		<dict>
			<key>Processor</key>
			<string>EndOfCheckPhase</string>
		</dict>
	</array>
</dict>
</plist>
